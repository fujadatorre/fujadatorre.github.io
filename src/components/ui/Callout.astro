---
import { Info, AlertTriangle, Lightbulb, Flame } from "@lucide/astro";

interface Props {
  type?: "note" | "observacao" | "warning" | "aviso" | "tip" | "dica" | "danger" | "perigo";
  title?: string;
  noHeader?: boolean;
}

const { type = "note", title, noHeader = false } = Astro.props;

const calloutTypes = {
  note: {
    icon: Info,
    color: "bg-blue-50 dark:bg-blue-900/30 text-blue-800 dark:text-blue-200 border-blue-200 dark:border-blue-800",
    iconColor: "text-blue-600 dark:text-blue-400",
    defaultTitle: "Nota",
  },
  observacao: {
    icon: Info,
    color: "bg-blue-50 dark:bg-blue-900/30 text-blue-800 dark:text-blue-200 border-blue-200 dark:border-blue-800",
    iconColor: "text-blue-600 dark:text-blue-400",
    defaultTitle: "Nota",
  },
  warning: {
    icon: AlertTriangle,
    color: "bg-amber-50 dark:bg-amber-900/30 text-amber-800 dark:text-amber-200 border-amber-200 dark:border-amber-800",
    iconColor: "text-amber-600 dark:text-amber-400",
    defaultTitle: "Aviso",
  },
  aviso: {
    icon: AlertTriangle,
    color: "bg-amber-50 dark:bg-amber-900/30 text-amber-800 dark:text-amber-200 border-amber-200 dark:border-amber-800",
    iconColor: "text-amber-600 dark:text-amber-400",
    defaultTitle: "Aviso",
  },
  tip: {
    icon: Lightbulb,
    color: "bg-emerald-50 dark:bg-emerald-900/30 text-emerald-800 dark:text-emerald-200 border-emerald-200 dark:border-emerald-800",
    iconColor: "text-emerald-600 dark:text-emerald-400",
    defaultTitle: "Dica",
  },
  dica: {
    icon: Lightbulb,
    color: "bg-emerald-50 dark:bg-emerald-900/30 text-emerald-800 dark:text-emerald-200 border-emerald-200 dark:border-emerald-800",
    iconColor: "text-emerald-600 dark:text-emerald-400",
    defaultTitle: "Dica",
  },
  danger: {
    icon: Flame,
    color: "bg-red-50 dark:bg-red-900/30 text-red-800 dark:text-red-200 border-red-200 dark:border-red-800",
    iconColor: "text-red-600 dark:text-red-400",
    defaultTitle: "Perigo",
  },
  perigo: {
    icon: Flame,
    color: "bg-red-50 dark:bg-red-900/30 text-red-800 dark:text-red-200 border-red-200 dark:border-red-800",
    iconColor: "text-red-600 dark:text-red-400",
    defaultTitle: "Perigo",
  },
};

const current = calloutTypes[type as keyof typeof calloutTypes] || calloutTypes.note;
const Icon = current.icon;
---
<div class={`my-6 border-l-4 rounded-r-lg p-5 ${current.color}`}>
  {!noHeader && (
    <div class="flex items-center gap-2 mb-2 font-bold">
      <div class={`shrink-0 ${current.iconColor}`}>
        <Icon size={20} />
      </div>
      <div>{title || current.defaultTitle}</div>
    </div>
  )}
  <div class={`text-sm prose prose-sm max-w-none dark:prose-invert [&>*:first-child]:mt-0 [&>*:last-child]:mb-0 ${noHeader ? "" : "sm:pl-7"}`}>
    <slot />
  </div>
</div>
