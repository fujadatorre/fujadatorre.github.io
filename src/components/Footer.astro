---
import { siteConfig } from "@/config";

---

<footer class="border-t border-border mt-20 py-10 px-10 lg:px-20">
    <div
        class="flex flex-col md:flex-row justify-between items-center gap-6"
    >
        <div class="flex flex-col items-center md:items-start gap-2">
            <span class="text-sm text-muted-foreground">
                &copy; {new Date().getFullYear()} {siteConfig.title} — <a href="mailto:fujadatorre@protonmail.com" class="hover:text-primary transition-colors">fujadatorre@protonmail.com</a>
            </span>
            <span class="text-xs text-muted-foreground">
                CC BY 4.0 - Licença Pública Creative Commons Atribuição 4.0 Internacional
            </span>
            <span class="text-xs text-muted-foreground">
                Desenvolvido com <a
                    href="https://astro.build"
                    target="_blank"
                    rel="noreferrer"
                    class="hover:text-primary transition-colors">Astro</a
                > — Tema <a
                    href="https://github.com/jiseeeh/serene-ink"
                    target="_blank"
                    rel="noreferrer"
                    class="hover:text-primary transition-colors">Serene Ink</a
                > por jiseeeh.
            </span>
        </div>

        <div class="flex items-center gap-4">
    <a href="/feed.xml" class="text-sm text-muted-foreground hover:text-primary transition-colors">Inscrever-se no RSS</a>
        </div>
    </div>
</footer>
