---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Writing from "@/components/Writing.astro";
import { siteConfig, seriesNames } from "@/config";
import { Image } from "astro:assets";
import torreImage from "../assets/torre.png";
import { Github, Twitter, Linkedin, BookOpen } from "@lucide/astro";

const entries = await getCollection("post");
const posts = entries.filter((entry) => import.meta.env.DEV || !entry.data.draft);

// 1. Obter Séries
const seriesCounts = new Map<string, number>();
posts.forEach((post) => {
    const parts = post.id.split("/");
    if (parts.length > 2) {
        const seriesKey = parts[1];
        if (seriesNames[seriesKey]) {
            seriesCounts.set(seriesKey, (seriesCounts.get(seriesKey) || 0) + 1);
        }
    }
});
const activeSeries = [...seriesCounts.entries()];

// 2. Obter Tags
const tagCounts = new Map<string, number>();
posts.forEach((post) => {
    post.data.tags.forEach((tag) => {
        tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
    });
});
const sortedTags = [...tagCounts.entries()]
    .sort((a, b) => b[1] - a[1])
    .slice(0, 12); // Mostra as 12 principais tags na Home
---

<Layout image="/images/home.webp">
    <main class="w-full flex flex-col space-y-24 px-5 sm:px-10 lg:px-20">
        
        {/* Seção 1: Apresentação (Boxes lado a lado) */}
        <section class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-6">
            
            {/* Box 1: Sobre o Autor */}
            <div class="bg-muted/30 dark:bg-neutral-900/30 border border-neutral-200/60 dark:border-neutral-800/60 rounded-2xl p-8 flex flex-col justify-between shadow-sm hover:border-primary/20 transition-all duration-300">
                <div>
                    <span class="text-xs uppercase text-primary font-medium tracking-widest">// autor</span>
                    <div class="flex items-center gap-4 mt-4 mb-5">
                        <Image 
                            src={torreImage} 
                            alt="Wesley Gueta" 
                            class="w-14 h-14 rounded-full border border-neutral-200 dark:border-neutral-800 shrink-0" 
                        />
                        <div>
                            <h2 class="text-2xl font-bold leading-tight">Wesley Gueta</h2>
                            <p class="text-xs text-muted-foreground mt-0.5">Criador e Autor</p>
                        </div>
                    </div>
                    <p class="text-sm text-muted-foreground leading-relaxed">
                        {siteConfig.author.bio}
                    </p>
                </div>
                
                <div class="flex items-center justify-between mt-8 pt-4 border-t border-neutral-200/40 dark:border-neutral-800/40">
                    <div class="flex items-center gap-3">
                        {siteConfig.socials.github && (
                            <a href={siteConfig.socials.github} target="_blank" rel="noreferrer" class="text-muted-foreground hover:text-primary transition-colors">
                                <Github size={18} />
                            </a>
                        )}
                        {siteConfig.socials.twitter && (
                            <a href={siteConfig.socials.twitter} target="_blank" rel="noreferrer" class="text-muted-foreground hover:text-primary transition-colors">
                                <Twitter size={18} />
                            </a>
                        )}
                        {siteConfig.socials.linkedin && (
                            <a href={siteConfig.socials.linkedin} target="_blank" rel="noreferrer" class="text-muted-foreground hover:text-primary transition-colors">
                                <Linkedin size={18} />
                            </a>
                        )}
                    </div>
                    <a href="/about" class="text-xs font-semibold text-primary hover:underline flex items-center gap-1">
                        Ler biografia completa →
                    </a>
                </div>
            </div>
            
            {/* Box 2: Linha Editorial */}
            <div class="bg-muted/30 dark:bg-neutral-900/30 border border-neutral-200/60 dark:border-neutral-800/60 rounded-2xl p-8 flex flex-col justify-between shadow-sm hover:border-primary/20 transition-all duration-300">
                <div>
                    <span class="text-xs uppercase text-primary font-medium tracking-widest">// manifesto</span>
                    <div class="flex items-center gap-3 mt-4 mb-5">
                        <div class="w-14 h-14 bg-primary/10 text-primary rounded-full flex items-center justify-center shrink-0 border border-primary/20">
                            <BookOpen size={24} />
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold leading-tight">Linha Editorial</h2>
                            <p class="text-xs text-muted-foreground mt-0.5">Princípios e Ética</p>
                        </div>
                    </div>
                    <p class="text-sm text-muted-foreground leading-relaxed">
                        Este blogue surge para contribuir com um debate público plural, fundamentado em evidências e na integridade científica. Guiamo-nos pela busca do esclarecimento, laicidade e pelo combate ativo à desinformação.
                    </p>
                </div>
                
                <div class="flex justify-end mt-8 pt-4 border-t border-neutral-200/40 dark:border-neutral-800/40">
                    <a href="/linha-editorial" class="text-xs font-semibold text-primary hover:underline flex items-center gap-1">
                        Ver manifesto completo →
                    </a>
                </div>
            </div>
            
        </section>

        {/* Seção 2: Séries Temáticas */}
        {activeSeries.length > 0 && (
            <section class="flex flex-col space-y-6">
                <div>
                    <span class="text-xs uppercase text-primary font-medium tracking-widest">SÉRIES ESPECIAIS</span>
                    <h2 class="text-3xl font-bold mt-2">Séries de Artigos</h2>
                    <p class="text-sm text-muted-foreground mt-1">Explorações encadeadas e aprofundadas sobre temáticas centrais.</p>
                </div>
                <div class="grid grid-cols-1 gap-4">
                    {activeSeries.map(([seriesKey, count]) => (
                        <a
                            href={`/series/${seriesKey}`}
                            class="group flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-muted/20 dark:bg-neutral-900/20 hover:bg-primary/5 px-6 py-5 rounded-xl border border-neutral-200/60 dark:border-neutral-800/60 hover:border-primary/20 transition-all duration-300 shadow-sm"
                        >
                            <div class="flex-1">
                                <h3 class="text-lg font-bold group-hover:text-primary transition-colors leading-tight">
                                    {seriesNames[seriesKey]}
                                </h3>
                                <p class="text-xs text-muted-foreground mt-1.5 leading-relaxed">
                                    Série de artigos dedicados a desmistificar a realidade sobre {seriesNames[seriesKey].toLowerCase()}.
                                </p>
                            </div>
                            <span class="self-start sm:self-center text-xs font-semibold bg-primary/10 text-primary px-3 py-1.5 rounded-full shrink-0">
                                {count} {count === 1 ? "artigo" : "artigos"}
                            </span>
                        </a>
                    ))}
                </div>
            </section>
        )}

        {/* Seção 3: Explorar por Tags */}
        {sortedTags.length > 0 && (
            <section class="flex flex-col space-y-6">
                <div>
                    <span class="text-xs uppercase text-primary font-medium tracking-widest">MAPA DE CONCEITOS</span>
                    <h2 class="text-3xl font-bold mt-2">Nuvens de Tags</h2>
                    <p class="text-sm text-muted-foreground mt-1">Explore os assuntos mais debatidos por palavras-chave.</p>
                </div>
                <div class="flex flex-wrap gap-2.5">
                    {sortedTags.map(([tag, count]) => (
                        <a
                            href={`/tags/${tag}`}
                            class="text-xs text-muted-foreground rounded-full bg-muted/50 dark:bg-neutral-900/50 border border-neutral-200/40 dark:border-neutral-800/40 px-3.5 py-1.5 hover:bg-primary/10 hover:text-primary hover:border-primary/20 transition-colors"
                        >
                            #{tag} <span class="text-[10px] opacity-60 ml-0.5">({count})</span>
                        </a>
                    ))}
                    <a
                        href="/tags"
                        class="text-xs font-semibold text-primary hover:underline px-3.5 py-1.5"
                    >
                        Ver todas as tags →
                    </a>
                </div>
            </section>
        )}

        <hr class="border-neutral-200/60 dark:border-neutral-800/60" />

        {/* Seção 4: Caderno de Publicações Recentes */}
        <div>
            <Writing page={1} />
        </div>
        
    </main>
</Layout>
