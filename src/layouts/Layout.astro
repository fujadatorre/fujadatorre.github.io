---
import "../styles/global.css";
import { Moon, Sun, Braces, Search, Rss, MousePointer2 } from "@lucide/astro";
import { ClientRouter } from "astro:transitions";
import { siteConfig } from "@/config";
import Footer from "@/components/Footer.astro";
import BackToTop from "@/components/BackToTop.astro";

interface Props {
    title?: string;
    description?: string;
    type?: string;
    image?: string;
}

const {
    title = siteConfig.title,
    description = siteConfig.description,
    type = "website",
    image,
} = Astro.props;

const canonicalURL = new URL(
    Astro.url.pathname,
    Astro.site || Astro.url.origin,
);

const normalize = (p: string) => p.replace(/\/+$/, "") || "/";

const isOnCurrentPath = (path: string) => {
    const currentPath = normalize(Astro.url.pathname);
    // treat paginated listing pages as part of the home route so the
    // home navigation item remains active on `/page/...` archive pages.
    if (path === "/" && currentPath.startsWith("/page/")) return true;
    return currentPath === normalize(path);
};

// Achar a página ativa para o menu mobile
const activeLink = siteConfig.nav.find((link) => isOnCurrentPath(link.href)) || { label: "Início", href: "/" };
---

<html lang="pt-br">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={description} />
        <ClientRouter />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="canonical" href={canonicalURL.href} />
        <link rel="icon" href="/favicon.ico" />

        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:type" content={type} />
        {
            image && (
                <meta
                    property="og:image"
                    content={
                        new URL(image, Astro.site || Astro.url.origin).href
                    }
                />
            )
        }
        {
            image && (
                <meta
                    name="twitter:image"
                    content={
                        new URL(image, Astro.site || Astro.url.origin).href
                    }
                />
            )
        }
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />

        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link
            rel="alternate"
            type="application/rss+xml"
            title={siteConfig.rss.title}
            href={new URL("feed.xml", Astro.url.origin)}
        />
        {
            siteConfig.analytics.umami.websiteId &&
                siteConfig.analytics.umami.src && (
                    <script
                        is:inline
                        defer
                        src={siteConfig.analytics.umami.src}
                        data-website-id={siteConfig.analytics.umami.websiteId}
                    />
                )
        }
        <script is:inline>
            const setDarkMode = () => {
                const theme = (() => {
                    if (
                        typeof localStorage !== "undefined" &&
                        localStorage.getItem("theme")
                    ) {
                        return localStorage.getItem("theme");
                    }
                    if (
                        window.matchMedia("(prefers-color-scheme: dark)")
                            .matches
                    ) {
                        return "dark";
                    }
                    return "light";
                })();
                if (theme === "light") {
                    document.documentElement.classList.remove("dark");
                } else {
                    document.documentElement.classList.add("dark");
                }
            };
            setDarkMode();
            document.addEventListener("astro:after-swap", setDarkMode);
        </script>
    </head>
    <body class="max-w-page mx-auto min-h-screen flex flex-col">
        <nav
            id="main-nav"
            class="px-5 py-4 grid grid-cols-2 md:flex md:flex-row md:items-center md:justify-between gap-4 md:gap-0 sticky top-0 z-50 bg-background/80 backdrop-blur-md border-b border-border/40 md:border-none"
        >
            <!-- Logo (Alinhado à esquerda no mobile) -->
            <div class="col-start-1 col-end-2 flex items-center md:order-1">
                <a href="/" aria-label="Página Inicial" class="flex items-center">
                    <Braces />
                </a>
            </div>

            <!-- Utilitários (Alinhados à direita no mobile, final no desktop) -->
            <ul class="col-start-2 col-end-3 flex justify-end items-center gap-4 md:order-3 md:w-auto">
                <li>
                    <button
                        id="theme-toggle"
                        type="button"
                        aria-label="Toggle dark mode"
                        class="flex items-center cursor-pointer"
                    >
                        <Moon class="block dark:hidden" size={16} />
                        <Sun class="hidden dark:block" size={16} />
                    </button>
                </li>
                <li>
                    <button
                        id="cursor-toggle"
                        type="button"
                        aria-label="Toggle custom cursor"
                        class="flex items-center transition-opacity cursor-pointer"
                    >
                        <MousePointer2 size={16} />
                    </button>
                </li>
                <li>
                    <a
                        href="/feed.xml"
                        aria-label="RSS feed"
                        class="flex items-center"
                    >
                        <Rss size={16} />
                    </a>
                </li>
                <li>
                    <button
                        id="search-toggle"
                        type="button"
                        aria-label="Open search"
                        class="flex items-center cursor-pointer"
                    >
                        <Search size={16} />
                    </button>
                </li>
            </ul>

            <!-- Mobile Navigation Dropdown Trigger (Apenas no mobile) -->
            <div class="col-span-2 md:hidden flex justify-between items-center bg-card/75 border border-border/80 rounded-xl px-4 py-2 relative w-full mt-1">
                <div class="flex items-center gap-2">
                    <span class="text-xs uppercase text-accent font-semibold tracking-wider">// página</span>
                    <span class="text-sm font-medium text-foreground">{activeLink.label}</span>
                </div>
                <button
                    id="mobile-nav-toggle"
                    aria-label="Abrir Menu"
                    class="text-xs uppercase tracking-wider text-muted-foreground border border-border px-2.5 py-1 rounded bg-secondary/80 hover:text-primary transition-all flex items-center gap-1.5 cursor-pointer font-semibold active:scale-95"
                >
                    <span>Menu</span>
                    <span id="mobile-nav-indicator" class="font-mono text-[10px]">[ + ]</span>
                </button>

                <!-- Dropdown Menu (Inicialmente oculto) -->
                <div
                    id="mobile-nav-dropdown"
                    class="absolute top-[3.25rem] left-0 right-0 z-50 border border-border rounded-xl p-3 bg-card shadow-2xl opacity-0 scale-95 pointer-events-none transition-all duration-200 origin-top"
                >
                    <ul class="flex flex-col gap-1 pl-0">
                        {
                            siteConfig.nav.map((link) => (
                                <li>
                                    <a
                                        href={link.href}
                                        class={`block py-2.5 px-3 rounded-lg hover:bg-secondary transition-colors text-sm ${
                                            isOnCurrentPath(link.href) ? "text-primary font-semibold bg-primary/10 border-l-2 border-primary pl-2" : "text-muted-foreground"
                                        }`}
                                    >
                                        {link.label}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>

            <!-- Links de Navegação Desktop (Escondidos no mobile, meio no desktop) -->
            <ul class="hidden md:flex items-center gap-6 overflow-x-auto overflow-y-hidden whitespace-nowrap pb-2 md:pb-0 scrollbar-none w-full md:w-auto justify-start md:justify-center -mx-5 px-5 md:mx-0 md:px-0 md:order-2">
                {
                    siteConfig.nav.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                class={
                                    isOnCurrentPath(link.href) ? "active" : ""
                                }
                            >
                                <span
                                    class={
                                        isOnCurrentPath(link.href)
                                            ? ""
                                            : "nav-link"
                                    }
                                >
                                    {link.label}
                                </span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
        <div class="flex-1">
            <slot />
        </div>
        <Footer />
        <BackToTop />
        <div
            id="search-overlay"
            class="fixed inset-0 z-100 bg-background/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 flex items-start justify-center pt-20 sm:pt-32 px-4 disable-select"
            aria-hidden="true"
            inert
        >
            <div
                id="search-modal"
                class="bg-card w-full max-w-xl rounded-xl border border-border shadow-2xl scale-95 transition-transform duration-300 flex flex-col overflow-hidden max-h-[80vh]"
            >
                <div
                    class="flex items-center px-4 py-3 border-b border-border gap-3"
                >
                    <Search class="text-muted-foreground" size={18} />
                    <input
                        type="text"
                        id="search-input"
                        class="flex-1 bg-transparent border-none outline-none text-foreground placeholder:text-muted-foreground"
                        placeholder="Buscar publicações... (Ctrl+K)"
                        autocomplete="off"
                    />
                    <button
                        id="search-close"
                        class="text-xs text-muted-foreground bg-secondary px-2 py-1 rounded hidden sm:block cursor-pointer"
                        >ESC</button
                    >
                </div>
                <div
                    id="search-results"
                    class="overflow-y-auto p-2 flex flex-col gap-1"
                >
                </div>
                <div
                    id="search-empty"
                    class="py-14 text-center text-sm text-muted-foreground hidden"
                >
                    Nenhum resultado encontrado.
                </div>
                <div
                    id="search-initial"
                    class="py-10 text-center text-sm text-muted-foreground"
                >
                    Digite para começar a buscar.
                </div>
            </div>
        </div>
        <div
            id="cursor"
            class="bg-primary mix-blend-hard-light opacity-0 size-3 rounded-full pointer-events-none z-9999 fixed top-0 left-0"
            transition:persist
        >
        </div>
        <script src="../scripts/cursor.ts"></script>
        <script>
            import type { SearchItem } from "../types";

            let onThemeToggleClick: ((e: MouseEvent) => void) | null = null;
            let onSearchToggleClick: ((e: MouseEvent) => void) | null = null;
            let onSearchCloseClick: ((e: MouseEvent) => void) | null = null;
            let onSearchOverlayClick: ((e: MouseEvent) => void) | null = null;
            let onSearchKeydown: ((e: KeyboardEvent) => void) | null = null;
            let onSearchInputRaw: ((e: Event) => void) | null = null;
            let searchData: SearchItem[] | null = null;

            let onNavScroll: (() => void) | null = null;
            let lastScrollY = 0;

            let onMobileNavToggleClick: ((e: MouseEvent) => void) | null = null;
            let onMobileNavDocumentClick: ((e: MouseEvent) => void) | null = null;

            document.addEventListener("astro:before-swap", () => {
                const themeToggle = document.getElementById("theme-toggle");
                if (onThemeToggleClick && themeToggle) {
                    themeToggle.removeEventListener(
                        "click",
                        onThemeToggleClick,
                    );
                    onThemeToggleClick = null;
                }

                const searchToggle = document.getElementById("search-toggle");
                const searchClose = document.getElementById("search-close");
                const searchOverlay = document.getElementById("search-overlay");
                const searchInput = document.getElementById("search-input");

                if (onSearchToggleClick && searchToggle)
                    searchToggle.removeEventListener(
                        "click",
                        onSearchToggleClick,
                    );
                if (onSearchCloseClick && searchClose)
                    searchClose.removeEventListener(
                        "click",
                        onSearchCloseClick,
                    );
                if (onSearchOverlayClick && searchOverlay)
                    searchOverlay.removeEventListener(
                        "click",
                        onSearchOverlayClick,
                    );
                if (onSearchInputRaw && searchInput)
                    searchInput.removeEventListener("input", onSearchInputRaw);
                if (onSearchKeydown)
                    document.removeEventListener("keydown", onSearchKeydown);

                onSearchToggleClick = null;
                onSearchCloseClick = null;
                onSearchOverlayClick = null;
                onSearchInputRaw = null;
                onSearchKeydown = null;

                if (onNavScroll) {
                    window.removeEventListener("scroll", onNavScroll);
                    onNavScroll = null;
                }

                const mobileNavToggle = document.getElementById("mobile-nav-toggle");
                if (onMobileNavToggleClick && mobileNavToggle) {
                    mobileNavToggle.removeEventListener("click", onMobileNavToggleClick);
                    onMobileNavToggleClick = null;
                }
                if (onMobileNavDocumentClick) {
                    document.removeEventListener("click", onMobileNavDocumentClick);
                    onMobileNavDocumentClick = null;
                }
            });

            document.addEventListener("astro:page-load", () => {
                // Mobile Navigation Dropdown Logic
                const mobileNavToggle = document.getElementById("mobile-nav-toggle");
                const mobileNavDropdown = document.getElementById("mobile-nav-dropdown");
                const mobileNavIndicator = document.getElementById("mobile-nav-indicator");
                let isMobileMenuOpen = false;

                if (mobileNavToggle && mobileNavDropdown && mobileNavIndicator) {
                    const menuClosed = ["opacity-0", "scale-95", "pointer-events-none"];
                    const menuOpen = ["opacity-100", "scale-100", "pointer-events-auto"];

                    const toggleMobileMenu = () => {
                        isMobileMenuOpen = !isMobileMenuOpen;
                        if (isMobileMenuOpen) {
                            mobileNavDropdown.classList.remove(...menuClosed);
                            mobileNavDropdown.classList.add(...menuOpen);
                            mobileNavIndicator.textContent = "[ - ]";
                        } else {
                            mobileNavDropdown.classList.remove(...menuOpen);
                            mobileNavDropdown.classList.add(...menuClosed);
                            mobileNavIndicator.textContent = "[ + ]";
                        }
                    };

                    onMobileNavToggleClick = (e: MouseEvent) => {
                        e.stopPropagation();
                        toggleMobileMenu();
                    };

                    mobileNavToggle.addEventListener("click", onMobileNavToggleClick);

                    onMobileNavDocumentClick = (e: MouseEvent) => {
                        if (isMobileMenuOpen && !mobileNavDropdown.contains(e.target as Node) && !mobileNavToggle.contains(e.target as Node)) {
                            toggleMobileMenu();
                        }
                    };
                    document.addEventListener("click", onMobileNavDocumentClick);
                }

                const themeToggle = document.getElementById("theme-toggle");
                if (!themeToggle) return;

                onThemeToggleClick = (event: MouseEvent) => {
                    const isDark =
                        document.documentElement.classList.contains("dark");

                    const toggleTheme = () => {
                        if (isDark) {
                            document.documentElement.classList.remove("dark");
                            localStorage.setItem("theme", "light");
                        } else {
                            document.documentElement.classList.add("dark");
                            localStorage.setItem("theme", "dark");
                        }
                    };

                    if (!document.startViewTransition) {
                        toggleTheme();
                        return;
                    }

                    const x = event.clientX;
                    const y = event.clientY;
                    // compute radius required to cover the entire viewport
                    // finds distance from click point to the farthest corner;
                    // hypot for calculating straight line distance
                    const endRadius = Math.hypot(
                        Math.max(x, innerWidth - x), // furthest horiz dist
                        Math.max(y, innerHeight - y), // furthest vert dist
                    );

                    document.documentElement.classList.add("theme-transition");

                    const transition = document.startViewTransition(() => {
                        toggleTheme();
                    });

                    transition.ready.then(() => {
                        const clipPath = [
                            `circle(0px at ${x}px ${y}px)`,
                            `circle(${endRadius}px at ${x}px ${y}px)`,
                        ];

                        document.documentElement.animate(
                            {
                                clipPath: clipPath,
                            },
                            {
                                duration: 500,
                                easing: "ease-in-out",
                                // targets the "new" snapshot layer created by the transition
                                pseudoElement: "::view-transition-new(root)",
                            },
                        );
                    });

                    // cleanup
                    transition.finished.finally(() => {
                        document.documentElement.classList.remove(
                            "theme-transition",
                        );
                    });
                };

                themeToggle.addEventListener("click", onThemeToggleClick);

                const searchToggle = document.getElementById("search-toggle");
                const searchClose = document.getElementById("search-close");
                const searchOverlay = document.getElementById("search-overlay");
                const searchModal = document.getElementById("search-modal");
                const searchInput = document.getElementById(
                    "search-input",
                ) as HTMLInputElement;
                const resultsContainer =
                    document.getElementById("search-results");
                const emptyState = document.getElementById("search-empty");
                const initialState = document.getElementById("search-initial");

                const openSearch = async () => {
                    if (!searchOverlay || !searchModal || !searchInput) return;
                    searchOverlay.removeAttribute("inert");
                    searchOverlay.setAttribute("aria-hidden", "false");
                    searchOverlay.classList.remove(
                        "opacity-0",
                        "pointer-events-none",
                    );
                    searchOverlay.classList.add("opacity-100");
                    searchModal.classList.remove("scale-95");
                    searchModal.classList.add("scale-100");
                    document.body.style.overflow = "hidden";
                    setTimeout(() => searchInput.focus(), 50);

                    if (!searchData) {
                        try {
                            const res = await fetch("/search.json");
                            searchData = await res.json();
                        } catch (e) {
                            console.error("Failed to load search index", e);
                        }
                    }
                };

                const closeSearch = () => {
                    if (!searchOverlay || !searchModal) return;
                    searchOverlay.setAttribute("inert", "");
                    searchOverlay.setAttribute("aria-hidden", "true");
                    searchOverlay.classList.add(
                        "opacity-0",
                        "pointer-events-none",
                    );
                    searchOverlay.classList.remove("opacity-100");
                    searchModal.classList.add("scale-95");
                    searchModal.classList.remove("scale-100");
                    document.body.style.overflow = "";
                };

                const renderResults = (query: string) => {
                    if (!resultsContainer || !emptyState || !initialState)
                        return;
                    if (!query.trim()) {
                        resultsContainer.classList.add("hidden");
                        emptyState.classList.add("hidden");
                        initialState.classList.remove("hidden");
                        return;
                    }
                    initialState.classList.add("hidden");
                    if (!searchData) return;

                    const q = query.toLowerCase();
                    const filtered = searchData.filter(
                        (post: SearchItem) =>
                            post.title.toLowerCase().includes(q) ||
                            post.frontmatter.toLowerCase().includes(q) ||
                            post.tags.some((tag: string) =>
                                tag.toLowerCase().includes(q),
                            ),
                    );

                    if (filtered.length === 0) {
                        resultsContainer.classList.add("hidden");
                        emptyState.classList.remove("hidden");
                    } else {
                        emptyState.classList.add("hidden");
                        resultsContainer.classList.remove("hidden");

                        resultsContainer.innerHTML = filtered
                            .map(
                                (post: SearchItem) => `
                            <a href="${post.link}" class="flex flex-col gap-1 p-3 rounded-lg hover:bg-secondary transition-colors group">
                                <div class="flex justify-between items-center bg-transparent">
                                    <span class="text-foreground font-medium group-hover:text-primary transition-colors line-clamp-1">${post.title}</span>
                                    <span class="text-xs text-muted-foreground whitespace-nowrap ml-4">${post.readTime} min · ${post.date}</span>
                                </div>
                                <span class="text-sm text-muted-foreground line-clamp-1">${post.frontmatter}</span>
                            </a>
                        `,
                            )
                            .join("");
                    }
                };

                onSearchToggleClick = () => openSearch();
                onSearchCloseClick = () => closeSearch();
                onSearchOverlayClick = (e: MouseEvent) => {
                    if (e.target === searchOverlay) closeSearch();
                };
                onSearchInputRaw = (e: Event) => {
                    const target = e.target as HTMLInputElement;
                    renderResults(target.value);
                };
                onSearchKeydown = (e: KeyboardEvent) => {
                    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
                        e.preventDefault();
                        openSearch();
                    } else if (e.key === "Escape") {
                        closeSearch();
                    }
                };

                if (searchToggle)
                    searchToggle.addEventListener("click", onSearchToggleClick);
                if (searchClose)
                    searchClose.addEventListener("click", onSearchCloseClick);
                if (searchOverlay)
                    searchOverlay.addEventListener(
                        "click",
                        onSearchOverlayClick,
                    );
                if (searchInput)
                    searchInput.addEventListener("input", onSearchInputRaw);
                document.addEventListener("keydown", onSearchKeydown);

                // scroll-aware navbar
                const nav = document.getElementById("main-nav");
                if (nav) {
                    lastScrollY = window.scrollY;

                    onNavScroll = () => {
                        const currentY = window.scrollY;

                        if (currentY > 100) {
                            nav.classList.add("nav-scrolled");
                        } else {
                            nav.classList.remove("nav-scrolled");
                        }

                        if (currentY > lastScrollY && currentY > 200) {
                            nav.classList.add("nav-hidden");
                        } else {
                            nav.classList.remove("nav-hidden");
                        }

                        lastScrollY = currentY;
                    };

                    window.addEventListener("scroll", onNavScroll);
                }
            });
        </script>
    </body>
</html>
